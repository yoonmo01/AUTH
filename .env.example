POSTGRES_PASSWORD=hyena_pw
NEO4J_CONTAINER=hyena_neo4j
NEO4J_USER=neo4j
NEO4J_PASSWORD=hyena_pw

# Optional AI stages. Leave empty for non-AI rebuild.
OPENAI_API_KEY=
UPSTAGE_API_KEY=

CLOVA_SPEECH_INVOKE_URL=
CLOVA_SPEECH_SECRET_KEY=

NCLOUD_ACCESS_KEY=
NCLOUD_SECRET_KEY=
NCLOUD_OBJECT_STORAGE_ENDPOINT=https://kr.object.ncloudstorage.com
NCLOUD_REGION=kr-standard
NCLOUD_BUCKET_NAME=auth-stt
NCLOUD_CLOVA_INPUT_PREFIX=original-mp4
NCLOUD_CLOVA_OUTPUT_PREFIX=result-stt
CLOVA_LANGUAGE=ko-KR
CLOVA_COMPLETION_MODE=sync
CLOVA_ENABLE_DIARIZATION=true
CLOVA_ENABLE_EVENT_DETECTION=true

# boto3 checksum 비활성화 (CLOVA STT S3 업로드 호환)
AWS_REQUEST_CHECKSUM_CALCULATION=when_required
AWS_RESPONSE_CHECKSUM_VALIDATION=when_required

QDRANT_URL=http://127.0.0.1:6333
OPENAI_VISION_MODEL=gpt-5-mini
UPSTAGE_ENTITY_MODEL=solar-pro3
