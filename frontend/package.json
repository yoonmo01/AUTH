{
  "name": "hyena-investigation-ui",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "electron:dev": "electron .",
    "electron:build": "electron-builder"
  },
  "build": {
    "appId": "com.hyena.analyzer",
    "productName": "AUTH - 정보 보안 자가 점검",
    "directories": {
      "output": "dist_electron"
    },
    "win": {
      "target": "nsis",
      "icon": "electron/AUTH.ico"
    },
    "files": [
      "electron/**/*"
    ],
    "extraResources": [
      { "from": "dist", "to": "dist" }
    ]
  },
  "dependencies": {
    "@dagrejs/dagre": "^3.0.0",
    "@tanstack/react-query": "^5.56.2",
    "@xyflow/react": "^12.3.2",
    "docx-preview": "^0.3.7",
    "html-to-image": "^1.11.13",
    "hwp.js": "^0.0.3",
    "mammoth": "^1.12.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-signature-canvas": "^1.1.0-alpha.2",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@types/react-signature-canvas": "^1.0.7",
    "@vitejs/plugin-react": "^4.3.1",
    "electron": "^42.2.0",
    "electron-builder": "^26.8.1",
    "jsdom": "^29.1.1",
    "typescript": "^5.5.3",
    "vite": "^5.4.1",
    "vitest": "^1.6.1"
  }
}
